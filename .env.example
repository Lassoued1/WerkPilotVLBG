# WerkPilot VLBG local deployment sample.
# Copy to .env for local use; never commit real pilot secrets.

# Compose profile intent:
# - local: include Mailpit for local password-reset mail capture.
# - test: include Mailpit with test-oriented external tooling.
# - pilot: omit Mailpit and set company SMTP relay values below.
COMPOSE_PROFILES=local

WERKPILOT_POSTGRES_DB=werkpilot
WERKPILOT_POSTGRES_USER=werkpilot
WERKPILOT_POSTGRES_PASSWORD=werkpilot
WERKPILOT_POSTGRES_PORT=5432

WERKPILOT_BACKEND_PORT=8080
WERKPILOT_FRONTEND_PORT=8081

APP_BASE_URL=http://localhost:8081

# Local/test profile defaults.
WERKPILOT_SMTP_HOST=mailpit
WERKPILOT_SMTP_PORT=1025
WERKPILOT_MAILPIT_SMTP_PORT=1025
WERKPILOT_MAILPIT_WEB_PORT=8025

# Pilot profile example values. Keep real values in .env or deployment secrets.
# COMPOSE_PROFILES=pilot
# WERKPILOT_SMTP_HOST=smtp.example.local
# WERKPILOT_SMTP_PORT=587

